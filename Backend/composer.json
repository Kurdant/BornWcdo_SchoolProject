{
    "name": "wcdo/backend",
    "description": "Backend PHP natif de la borne de commande WCDO",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "WCDO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WCDO\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "config": {
        "optimize-autoloader": true
    }
}
